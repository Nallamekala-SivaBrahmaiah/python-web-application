# API Gateway
PORT=3000
JWT_SECRET=your-super-secret-jwt-key-change-this

# Database URLs
AUTH_DB_URL=postgresql://user:password@auth-db:5432/auth_db
USER_DB_URL=postgresql://user:password@user-db:5432/user_db
RESTAURANT_DB_URL=postgresql://user:password@restaurant-db:5432/restaurant_db
MENU_DB_URL=postgresql://user:password@menu-db:5432/menu_db
ORDER_DB_URL=postgresql://user:password@order-db:5432/order_db

# Redis
REDIS_URL=redis://redis:6379

# Service URLs
AUTH_SERVICE_URL=http://auth-service:3001
USER_SERVICE_URL=http://user-service:3002
RESTAURANT_SERVICE_URL=http://restaurant-service:3003
MENU_SERVICE_URL=http://menu-service:3004
ORDER_SERVICE_URL=http://order-service:3005
NOTIFICATION_SERVICE_URL=http://notification-service:3006

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
